{
  "manifest_version": 3,
  "name": "Linkedin Job Helper",
  "version": "1.5.0",
  "description": "Highlights Viewed/Applied/Saved jobs and exports non-VAS jobs to your API.",
  "icons": {
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
