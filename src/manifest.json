{
  "manifest_version": 3,
  "name": "Linkedin Job Helper",
  "version": "1.6.5",
  "description": "Highlights Viewed/Applied/Saved jobs and exports non-VAS jobs to your API.",
  "icons": { "128": "icon.png" },
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://YOUR-API-HOST.example.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Linkedin Job Helper",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
